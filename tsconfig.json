{
  "compilerOptions": {
    "lib": [
      "esnext"
    ],
    "target": "es2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "outDir": "dist",
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noEmit": false
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules"
  ]
}